void deleteStudent() {
    int roll, found = 0;
    printf("Enter roll to delete: ");
    scanf("%d", &roll);

    for (int i = 0; i < count; i++) {
        if (students[i].roll == roll) {
            for (int j = i; j < count - 1; j++) {
                students[j] = students[j + 1];
            }
            count--;
            saveToFile();
            printf("Deleted!\n");
            found = 1;
            break;
        }
    }

    if (!found) printf("Not found!\n");
}

